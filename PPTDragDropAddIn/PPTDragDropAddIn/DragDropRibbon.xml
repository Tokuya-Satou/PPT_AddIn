<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="Ribbon_Load">
  <ribbon>
    <tabs>
      <tab id="tabPPTDrag" label="PPTドラッグ">

        <group id="grpControl" label="制御">
          <toggleButton id="tglDragDrop"
                        label="ドラッグ移動"
                        getPressed="GetDragDropPressed"
                        onAction="OnToggleDragDrop"
                        size="large"
                        imageMso="ControlProperties" />
          <toggleButton id="tglPenPalette"
                        label="ペンパレット"
                        getPressed="GetPenPalettePressed"
                        onAction="OnTogglePenPalette"
                        size="large"
                        imageMso="InkAnnotations" />
        </group>

        <group id="grpPen" label="ペン設定">
          <splitButton id="splitPen1" size="normal">
            <button id="btnPen1Main"
                    getLabel="GetPenLabel"
                    getImage="GetPenImage"
                    onAction="OnPenMain" />
            <menu id="menuPen1">
              <button id="btnPen1Black"  label="黒"     tag="Black_1"  onAction="OnPenColor" getImage="GetColorImage" />
              <button id="btnPen1Red"    label="赤"     tag="Red_1"    onAction="OnPenColor" getImage="GetColorImage" />
              <button id="btnPen1Blue"   label="青"     tag="Blue_1"   onAction="OnPenColor" getImage="GetColorImage" />
              <button id="btnPen1Green"  label="緑"     tag="Green_1"  onAction="OnPenColor" getImage="GetColorImage" />
              <button id="btnPen1White"  label="白"     tag="White_1"  onAction="OnPenColor" getImage="GetColorImage" />
              <button id="btnPen1Orange" label="オレンジ" tag="Orange_1" onAction="OnPenColor" getImage="GetColorImage" />
              <button id="btnPen1Purple" label="紫"     tag="Purple_1" onAction="OnPenColor" getImage="GetColorImage" />
            </menu>
          </splitButton>

          <splitButton id="splitPen2" size="normal">
            <button id="btnPen2Main"
                    getLabel="GetPenLabel"
                    getImage="GetPenImage"
                    onAction="OnPenMain" />
            <menu id="menuPen2">
              <button id="btnPen2Black"  label="黒"     tag="Black_2"  onAction="OnPenColor" getImage="GetColorImage" />
              <button id="btnPen2Red"    label="赤"     tag="Red_2"    onAction="OnPenColor" getImage="GetColorImage" />
              <button id="btnPen2Blue"   label="青"     tag="Blue_2"   onAction="OnPenColor" getImage="GetColorImage" />
              <button id="btnPen2Green"  label="緑"     tag="Green_2"  onAction="OnPenColor" getImage="GetColorImage" />
              <button id="btnPen2White"  label="白"     tag="White_2"  onAction="OnPenColor" getImage="GetColorImage" />
              <button id="btnPen2Orange" label="オレンジ" tag="Orange_2" onAction="OnPenColor" getImage="GetColorImage" />
              <button id="btnPen2Purple" label="紫"     tag="Purple_2" onAction="OnPenColor" getImage="GetColorImage" />
            </menu>
          </splitButton>

          <splitButton id="splitPen3" size="normal">
            <button id="btnPen3Main"
                    getLabel="GetPenLabel"
                    getImage="GetPenImage"
                    onAction="OnPenMain" />
            <menu id="menuPen3">
              <button id="btnPen3Black"  label="黒"     tag="Black_3"  onAction="OnPenColor" getImage="GetColorImage" />
              <button id="btnPen3Red"    label="赤"     tag="Red_3"    onAction="OnPenColor" getImage="GetColorImage" />
              <button id="btnPen3Blue"   label="青"     tag="Blue_3"   onAction="OnPenColor" getImage="GetColorImage" />
              <button id="btnPen3Green"  label="緑"     tag="Green_3"  onAction="OnPenColor" getImage="GetColorImage" />
              <button id="btnPen3White"  label="白"     tag="White_3"  onAction="OnPenColor" getImage="GetColorImage" />
              <button id="btnPen3Orange" label="オレンジ" tag="Orange_3" onAction="OnPenColor" getImage="GetColorImage" />
              <button id="btnPen3Purple" label="紫"     tag="Purple_3" onAction="OnPenColor" getImage="GetColorImage" />
            </menu>
          </splitButton>

          <splitButton id="splitMarker" size="normal">
            <button id="btnMarkerMain"
                    getLabel="GetMarkerLabel"
                    getImage="GetMarkerImage"
                    onAction="OnMarkerMain" />
            <menu id="menuMarker">
              <button id="btnMarkerYellow"     label="黄"   tag="Yellow"     onAction="OnMarkerColor" getImage="GetColorImage" />
              <button id="btnMarkerCyan"       label="水色" tag="Cyan"       onAction="OnMarkerColor" getImage="GetColorImage" />
              <button id="btnMarkerOrange"     label="橙"   tag="Orange"     onAction="OnMarkerColor" getImage="GetColorImage" />
              <button id="btnMarkerLightGreen" label="黄緑" tag="LightGreen" onAction="OnMarkerColor" getImage="GetColorImage" />
              <button id="btnMarkerPink"       label="ピンク" tag="Pink"     onAction="OnMarkerColor" getImage="GetColorImage" />
            </menu>
          </splitButton>
        </group>

      </tab>
    </tabs>
  </ribbon>

  <contextMenus>
    <contextMenu idMso="ContextMenuShape">
      <button id="EnableDragShape"
              getLabel="GetDragLabel"
              onAction="OnToggleDrag"
              insertAfterMso="ShapeFormat"/>
    </contextMenu>
    <contextMenu idMso="ContextMenuPicture">
      <button id="EnableDragPicture"
              getLabel="GetDragLabel"
              onAction="OnToggleDrag"
              insertAfterMso="PictureFormat"/>
    </contextMenu>
  </contextMenus>
</customUI>
