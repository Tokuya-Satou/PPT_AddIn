<Window x:Class="PPTDragDropAddIn.PenPaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PenPalette"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="PenButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#88FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#44FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#66FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#99FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAFFFFFF"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#EE1A1A2E" CornerRadius="10" Margin="4" MinWidth="160">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.7" ShadowDepth="2"/>
        </Border.Effect>
        <StackPanel Margin="8">

            <!-- タイトル行: ドラッグハンドル + 最小化ボタン -->
            <Grid Margin="0,2,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="TitleText" Text="✏ ペンパレット"
                           Foreground="#AAFFFFFF" FontSize="11" FontWeight="Bold"
                           VerticalAlignment="Center"
                           MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                           Cursor="SizeAll"/>
                <Button Grid.Column="1" x:Name="BtnToggle" Content="−"
                        Style="{StaticResource IconButtonStyle}"
                        Foreground="#AAFFFFFF" FontSize="13" FontWeight="Bold"
                        Click="BtnToggle_Click"/>
            </Grid>

            <!-- 折りたたみ可能なコンテンツ -->
            <StackPanel x:Name="PanelContent">

                <!-- 黒ペン -->
                <Button x:Name="BtnBlackPen" Style="{StaticResource PenButtonStyle}"
                        Click="BtnBlackPen_Click" Margin="0,2">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="14" Height="14" Fill="#111111" Stroke="#AAAAAA" StrokeThickness="1" VerticalAlignment="Center"/>
                        <TextBlock Text=" 黒ペン" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- 赤ペン -->
                <Button x:Name="BtnRedPen" Style="{StaticResource PenButtonStyle}"
                        Click="BtnRedPen_Click" Margin="0,2">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="14" Height="14" Fill="#FF3333" Stroke="#AAAAAA" StrokeThickness="1" VerticalAlignment="Center"/>
                        <TextBlock Text=" 赤ペン" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- 青ペン -->
                <Button x:Name="BtnBluePen" Style="{StaticResource PenButtonStyle}"
                        Click="BtnBluePen_Click" Margin="0,2">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="14" Height="14" Fill="#3355FF" Stroke="#AAAAAA" StrokeThickness="1" VerticalAlignment="Center"/>
                        <TextBlock Text=" 青ペン" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- 黄色マーカー -->
                <Button x:Name="BtnYellowMarker" Style="{StaticResource PenButtonStyle}"
                        Click="BtnYellowMarker_Click" Margin="0,2">
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="16" Height="10" Fill="#FFFF00" Stroke="#AAAAAA" StrokeThickness="1" VerticalAlignment="Center"/>
                        <TextBlock Text=" 黄色ペン" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- 消しゴム -->
                <Button x:Name="BtnEraser" Style="{StaticResource PenButtonStyle}"
                        Click="BtnEraser_Click" Margin="0,2">
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="16" Height="10" Fill="White" Stroke="#AAAAAA" StrokeThickness="1" VerticalAlignment="Center"/>
                        <TextBlock Text=" 消しゴム" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Separator Background="#33FFFFFF" Margin="0,6"/>

                <!-- カーソルに戻す -->
                <Button x:Name="BtnArrow" Style="{StaticResource PenButtonStyle}"
                        Click="BtnArrow_Click" Margin="0,2,0,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↖" Foreground="#CCCCCC" FontSize="14" Width="14" VerticalAlignment="Center"/>
                        <TextBlock Text=" カーソル" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Separator Background="#33FFFFFF" Margin="0,0,0,6"/>

                <!-- スライドナビゲーション: 戻る / 次へ -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="BtnPrev" Style="{StaticResource NavButtonStyle}"
                            Click="BtnPrev_Click">
                        <TextBlock Text="◀ 戻る" Foreground="White" FontSize="11"/>
                    </Button>
                    <Button Grid.Column="2" x:Name="BtnNext" Style="{StaticResource NavButtonStyle}"
                            Click="BtnNext_Click">
                        <TextBlock Text="次へ ▶" Foreground="White" FontSize="11"/>
                    </Button>
                </Grid>

            </StackPanel>
        </StackPanel>
    </Border>
</Window>
